
@model CreateGameViewModel

@{
    ViewData["Title"] = "Add Game";
}

<h5>
    <i class="bi bi-plus-circle btn-lg"></i>
    Add a new Game
</h5>

<form asp-action="Create" asp-controller="Games" enctype="multipart/form-data">
    <div class="row">
        <!-- For Inputs at left -->
        <div class="col-md-4">
            <!-- For Name -->
            <div class="form-group">
                <label asp-for="Name" class="form-label mt-4"></label>
                <input type="text" asp-for="Name" class="form-control" placeholder="Enter Name">
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <!-- For Gategory -->
            <div class="form-group">
                <label asp-for="CategoryId" class="form-label mt-4"></label>
                <select asp-for="CategoryId" class="form-select" asp-items="Model.Categories">
                    <option value="">Select a Category</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <!-- For Devices -->
            <div class="form-group">
                <label asp-for="SelectedDevices" class="form-label mt-4"></label>
                <select asp-for="SelectedDevices" class="form-select" asp-items="Model.Devices">
                    <option value="">Select Devices</option>
                </select>
                <span asp-validation-for="SelectedDevices" class="text-danger"></span>
            </div>


            <!-- For Desc -->
            <div class="form-group">
                <label asp-for="Desc" class="form-label mt-4"></label>
                <textarea asp-for="Desc" class="form-control" placeholder="Enter Description"></textarea>
                <span asp-validation-for="Desc" class="text-danger"></span>
            </div>


            <!-- For Cover Image -->
            <div class="form-group">
                <label asp-for="Cover" class="form-label mt-4">Game Cover</label>
                <input asp-for="Cover" class="form-control" type="file">
                <small class="form-text text-muted">Only @FileSettings.AllowedExtentions files allowed with max size @(FileSettings.MaxFileSizeInMB)MB.</small>
                <span asp-validation-for="Cover" class="text-danger d-block"></span>
            </div>


            <button type="submit" class="btn btn-primary mt-4">Submit</button>
        </div>
    

        <!-- For Image preview at right -->
        <div class="col-md-4"></div>
        <div class="col-md-4">

        </div>
    </div>

</form>
 

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}